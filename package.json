{
  "name": "portfolio",
  "version": "1.12.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=4.0.0"
  },
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "analyze": "node scripts/check-node-version.mjs && source-map-explorer 'build/assets/*.js'",
    "browserslist:update": "yarn update-browserslist-db@latest",
    "build": "node scripts/check-node-version.mjs && vite build",
    "dev": "node scripts/check-node-version.mjs && vite",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "lint:commits": "commitlint --edit",
    "lint:css:fix": "stylelint \"src/**/*.css\" \"tests/**/*.css\" --fix",
    "lint:css": "stylelint \"src/**/*.css\" \"tests/**/*.css\"",
    "lint:eslint:fix": "node scripts/check-node-version.mjs && eslint src/**/*.{js,jsx,ts,tsx} tests/**/*.{js,jsx,ts,tsx} --fix",
    "lint:eslint": "node scripts/check-node-version.mjs && eslint src/**/*.{js,jsx,ts,tsx} tests/**/*.{js,jsx,ts,tsx}",
    "lint:fix": "yarn lint:eslint:fix && yarn lint:css:fix && yarn format",
    "lint:types": "node scripts/check-node-version.mjs && tsc --noEmit",
    "lint": "node scripts/check-node-version.mjs && node scripts/lint-with-progress.mjs && yarn format:check",
    "preanalyze": "node scripts/check-node-version.mjs",
    "prebuild": "node scripts/check-node-version.mjs",
    "predev": "node scripts/check-node-version.mjs",
    "prelint:eslint:fix": "node scripts/check-node-version.mjs",
    "prelint:eslint": "node scripts/check-node-version.mjs",
    "prelint:types": "node scripts/check-node-version.mjs",
    "prelint": "node scripts/check-node-version.mjs",
    "prepare": "husky",
    "prepreview": "node scripts/check-node-version.mjs",
    "prestart": "node scripts/check-node-version.mjs",
    "pretest:coverage": "node scripts/check-node-version.mjs",
    "pretest:e2e:headed": "node scripts/check-node-version.mjs",
    "pretest:e2e:ui": "node scripts/check-node-version.mjs",
    "pretest:e2e": "node scripts/check-node-version.mjs",
    "pretest:ui": "node scripts/check-node-version.mjs",
    "pretest:watch": "node scripts/check-node-version.mjs",
    "pretest": "node scripts/check-node-version.mjs",
    "preview": "node scripts/check-node-version.mjs && vite preview",
    "start": "node scripts/check-node-version.mjs && vite",
    "test:all": "yarn test && yarn test:lighthouse && yarn test:e2e",
    "test:coverage": "node scripts/check-node-version.mjs && vitest run --coverage",
    "test:e2e:headed": "node scripts/check-node-version.mjs && playwright test --headed",
    "test:e2e:ui": "node scripts/check-node-version.mjs && playwright test --ui",
    "test:e2e": "node scripts/check-node-version.mjs && playwright test",
    "test:e2e:desktop": "node scripts/check-node-version.mjs && playwright test tests/e2e/desktop --project=chromium",
    "test:e2e:desktop:webkit": "node scripts/check-node-version.mjs && playwright test tests/e2e/desktop --project=webkit --workers=1",
    "test:e2e:mobile": "node scripts/check-node-version.mjs && playwright test tests/e2e/mobile --project=\"Mobile Chrome\"",
    "test:e2e:mobile:safari": "node scripts/check-node-version.mjs && playwright test tests/e2e/mobile --project=\"Mobile Safari\" --workers=1",
    "test:lighthouse:both": "./scripts/run-lighthouse.sh both",
    "test:lighthouse:desktop": "./scripts/run-lighthouse.sh desktop",
    "test:lighthouse:mobile": "./scripts/run-lighthouse.sh mobile",
    "test:lighthouse": "./scripts/run-lighthouse.sh desktop",
    "test:ui": "node scripts/check-node-version.mjs && vitest --ui",
    "test:watch": "node scripts/check-node-version.mjs && vitest",
    "test": "node scripts/check-node-version.mjs && vitest run"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,scss,md}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "bash -c 'tsc --noEmit'"
    ]
  },
  "dependencies": {
    "animate.css": "^4.1.1",
    "classnames": "^2.5.1",
    "react": "^19.2.4",
    "react-animate-on-scroll": "^2.1.9",
    "react-dom": "^19.2.4",
    "react-inlinesvg": "^4.2.0",
    "swiper": "^12.1.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.0",
    "postcss": "^8.5.10",
    "prettier": "^3.9.5",
    "prettier-plugin-css-order": "^2.2.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "semantic-release": "^25.0.8",
    "source-map-explorer": "^2.5.2",
    "stylelint": "^17.14.1",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.1.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
